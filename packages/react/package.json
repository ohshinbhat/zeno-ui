{
  "name": "@zenoui/react",
  "version": "1.1.0",
  "description": "Zeno UI web primitives and hosted theme runtime.",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ohshinbhat/zeno-ui.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/ohshinbhat/zeno-ui/tree/main/packages/react",
  "bugs": {
    "url": "https://github.com/ohshinbhat/zeno-ui/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "tailwindcss": ">=3.4.0 || >=4.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  }
}
